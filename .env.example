# Supabase (portal) — copy to .env.local and fill real values
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_LOCAL_ANON_KEY_HERE

# Service role (E2E test only — never commit, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# OAuth (Plan 2 Task 5 fills these — server-side only, set via supabase secrets or .env.local)
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
SUPABASE_AUTH_FACEBOOK_CLIENT_ID=
SUPABASE_AUTH_FACEBOOK_SECRET=
