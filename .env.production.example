# Production environment — copy to .env.production and fill in values from Supabase dashboard
# Sau khi tạo project "Dai Long Portal" trên supabase.com → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-from-dashboard>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-dashboard>

# URL gốc của portal trên domain thật (dùng để gen QR referral supervisor)
NEXT_PUBLIC_PORTAL_URL=https://dailongai.com

# Google OAuth — lấy từ GCP project "dailongai-portal"
# Thêm redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
SUPABASE_AUTH_GOOGLE_CLIENT_ID=999543749344-dme78u9snfa401ull3nr2as1a5ra0a1k.apps.googleusercontent.com
SUPABASE_AUTH_GOOGLE_SECRET=<google-secret>

# Facebook OAuth — lấy từ Meta app "Dai Long Portal" (ID 1290644193226709)
# Thêm redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
SUPABASE_AUTH_FACEBOOK_CLIENT_ID=1290644193226709
SUPABASE_AUTH_FACEBOOK_SECRET=<facebook-secret>
